//-
  検索入力エリア（タブ切り替え）
  data-bound-url-param="mode" がある場合、初期タブ選択は URL の ?mode= を優先して決まる（タブ操作で URL は更新しない）。
  Simple / Advanced の切り替えは module-tabs-view の JS が .section/-current クラスで制御する。
#SearchInputView.module-tabs-view(data-bound-url-param="mode")

  //- タブナビゲーション（Simple search / Advanced search の切り替えボタン）
  nav.tabscontainer
    ul
      li(data-tab-group="tab-group-type-of-search" data-target="simple") Simple search
      li(data-tab-group="tab-group-type-of-search" data-target="advanced") Advanced search

  //- 各タブのコンテンツ領域
  //- 非アクティブな .section は CSS で position:absolute / visibility:hidden になりフロー外に置かれる。
  //- アクティブな .section.-current のみが高さを持ち、#SearchInputView の高さに反映される。
  .sectionscontainer

    //- Simple Search のコンテンツは JS が動的に挿入する（初期は空）
    #SimpleSearchView.section(data-tab-id="simple")

    //- Advanced Search のコンテンツ領域
    #AdvancedSearchView.section(data-tab-id="advanced")
      //-
        条件ビルダーのルートコンテナ
        .section クラスは JS の条件管理コードから参照されるが、
        module-tabs-view の > .section ルール（直接子セレクター）には該当しないため
        position:absolute は適用されない。
      #AdvancedSearchBuilderView.section
        //- 条件行・グループは JS（AdvancedSearchBuilderView.ts）が .inner に動的挿入する
        .inner

//-
  検索結果エリア
  #SearchInputView とは body の flex column 上の兄弟要素。
  #SearchInputView の高さ変化（タブ切り替え・折りたたみ）に追従して
  main の開始位置が自動的にずれる。
  .LayoutMainAside / .LayoutMain / .LayoutAside の flex 構造は _layout.scss で定義。
main#SearchResultsView.LayoutMainAside

  .LayoutMain

    //-
      結果テーブルとヘッダーを包むメインカラム
      padding: 10px $PADDING_SIDE $PADDING_SIDE は _ResultsView.scss で定義。
    #ResultsView

      //- ヘッダー行：見出し・結果件数・ダウンロードボタン・列切り替えドロップダウン
      header.header
        .left
          h2.heading Results
          .status Loading results...
        ul.right
          li.text Download
          li.download-buttons
            button#DownloadJson.button-view.-disabled(data-filetype="json") JSON
            button#DownloadCsv.button-view.-disabled(data-filetype="csv") CSV
            button#DownloadTsv.button-view.-disabled(data-filetype="txt") TSV
          li.columns-dropdown
            //- aria-expanded は JS がドロップダウン開閉に合わせて更新する
            button.columns-dropdown-button.button-view.-dropdown(type='button' aria-expanded='false') Columns
            //- hidden / aria-hidden / inert でスクリーンリーダーと Tab フォーカスから除外する
            .columns-dropdown-menu(hidden aria-hidden='true' inert)
              ul.columns-dropdown-list
          //- ダウンロード不可の理由（条件未入力など）を aria-live で読み上げる
          li.download-disabled-reason-item(hidden)
            span#DownloadDisabledReason.download-disabled-reason(role='status' aria-live='polite' hidden)

      //- 検索状態メッセージ（ローディング中・件数ゼロ・エラーなど）を JS が挿入する
      #Messages

      //- 仮想スクロール用テーブルコンテナ（行の表示/非表示切り替えは JS が制御）
      .tablecontainer
        //- tablecontainer を基準にローディングアイコンを絶対配置する
        include _loading_indicator
        table.results-view
          thead
            //-
              列ヘッダー行
              各 th のクラス名は _results-view.scss の列幅定義・JS の列リサイズ処理と対応している。
              data-tooltip-id はツールチップの表示に使う（JS が参照）。
            tr
              th.togovar_id
                span(data-tooltip-id="table-header-togovar_id") TogoVar ID
              th.refsnp_id
                span(data-tooltip-id="table-header-refsnp_id") RefSNP ID
              th.position
                span(data-tooltip-id="table-header-position") Position
              th.ref_alt
                span(data-tooltip-id="table-header-ref_alt") Ref / Alt
              th.type
                span(data-tooltip-id="table-header-type") Type
              th.gene
                span(data-tooltip-id="table-header-gene") Gene
              th.alt_frequency
                span(data-tooltip-id="table-header-alt_frequency") Alt frequency
              th.consequence
                span(data-tooltip-id="table-header-consequence") Consequence
              th.clinical_significance
                span(data-tooltip-id="table-header-clinical_significance") Clinical significance
              th.alphamissense
                span(data-tooltip-id="table-header-alphamissense") AlphaMissense
              th.sift
                span(data-tooltip-id="table-header-sift") SIFT
              th.polyphen
                span(data-tooltip-id="table-header-polyphen") PolyPhen

          //- tbody は JS（ResultsView の仮想スクロール）が行を動的挿入する
          tbody

      //- 表示中の行番号インジケーター（JS が現在のスクロール位置に応じて更新）
      #RowIndicator.row-indicator

  //- フィルタ・プレビューを表示するサイドバー（Simple / Advanced 両モードで常に表示）
  .LayoutAside
    aside#SideBar

      //- バリアントプレビュー（行クリック時にサイドバーに展開される詳細情報）
      #Previews.sidebarcontent
        h2.title Preview
        a#PreviewToVariantReport.panel-view.-cannotcollapse.-emphasize
          h3.title Detailed variant report page
        section#PreviewGene.panel-view
          h3.title Genes
          .content
            dl.property-list
        section#PreviewExternalLinks.panel-view
          h3.title External links
          .content
            dl.property-list
        section#PreviewAlternateAlleleFrequencies.panel-view
          h3.title Alternate allele frequencies
          .content
            table.frequency-table
              thead
                tr
                  th Dataset
                  th Alt
                  th Total
                  th Frequency
              tbody
        section#PreviewConsequence.panel-view
          h3.title Consequence
          .content
        section#PreviewClinicalSignificance.panel-view
          h3.title Clinical significance
          .content

      //- 絞り込みフィルター群（Simple モード時のみ表示される項目も含む）
      #Filters.sidebarcontent
        h2.title
          span.simple Statistics / Filters
          span.advanced Statistics
          button.button-view Clear all
        section#FilterDatasets.panel-view
          h3.title
            | Dataset
            button.clear-button.button-view Clear
          .content
            ul.checklist-values
        section#FilterAlternateAlleleFrequency.panel-view
          h3.title Alternate allele frequency
          .content
            .range-selector-view
        section#FilterVariantCallingQuality.panel-view
          h3.title Variant calling quality
          .content
            label.label
              input(checked='checked', type='checkbox')
              | Exclude filtered out variants in all datasets
        section#FilterVariantType.panel-view
          h3.title
            | Variant type
            button.clear-button.button-view Clear
          .content
            ul.checklist-values
        section#FilterConsequence.panel-view
          h3.title
            | Consequence
            button.clear-button.button-view Clear
          .content
            ul.checklist-values
        section#FilterClinicalSignificance.panel-view
          h3.title
            | Clinical significance
            button.clear-button.button-view Clear
          .content
            ul.checklist-values
        section#FilterCADD.panel-view
          h3.title
            | CADD (PHRED score)
            button.clear-button.button-view Clear
          .content
            ul.checklist-values
        section#FilterAlphaMissense.panel-view
          h3.title
            | AlphaMissense
            button.clear-button.button-view Clear
          .content
            ul.checklist-values
        section#FilterSIFT.panel-view
          h3.title
            | SIFT
            button.clear-button.button-view Clear
          .content
            ul.checklist-values
        section#FilterPolyPhen.panel-view
          h3.title
            | PolyPhen
            button.clear-button.button-view Clear
          .content
            ul.checklist-values
        section#FilterSplicingVariant.panel-view
          h3.title
            | Splicing variant (SSCV DB)
            button.clear-button.button-view Clear
          .content
            ul.checklist-values

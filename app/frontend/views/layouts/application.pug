block variables
  include ../includes/_globals
  - lang = locals.language ? locals.language : "en";
  - scrollDelay = 500

doctype html
html(data-page=locals.currentPage, lang=lang)
  head
    title= locals.title ? locals.title : "TogoVar"
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    meta(name="description" content=locals.description ? locals.description : "TogoVar is an integrated database of Japanese genomic variation, providing allele frequencies and annotations for human variants.")
    - canonicalHref = locals.canonicalUrl || (typeof canonicalUrl !== "undefined" ? canonicalUrl : null)
    - fontStylesheetHref = "https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@300;400;700;900&display=optional"
    if canonicalHref
      link(rel="canonical" href=canonicalHref)
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(rel="preload" href=fontStylesheetHref as="style")
    link(rel="stylesheet" href=fontStylesheetHref media="print" id="font-stylesheet")
    noscript
      link(rel="stylesheet" href=fontStylesheetHref)
    link(rel="icon" href="/favicon.svg" type="image/svg+xml")
    script.
      (function() {
        var f = document.getElementById('font-stylesheet');
        if (!f) return;

        var activateFontStylesheet = function() { f.media = 'all'; };
        f.addEventListener('load', activateFontStylesheet, { once: true });
        if (f.sheet) activateFontStylesheet();
      })();
      (function() {
        var page = document.documentElement.getAttribute('data-page');
        if (page !== 'variant' && page !== 'gene' && page !== 'disease') return;

        var canonicalLink = document.querySelector('link[rel="canonical"]');
        if (!canonicalLink) {
          canonicalLink = document.createElement('link');
          canonicalLink.setAttribute('rel', 'canonical');
          document.head.appendChild(canonicalLink);
        }

        // レポート詳細は旧Express配信時と同じ末尾スラッシュなしを正規URLとして扱う。
        var canonicalPath = window.location.pathname.replace(/^\/(variant|gene|disease)\/([^/]+)\/$/, '/$1/$2');
        canonicalLink.href = "#{TOGOVAR_FRONTEND_SITE_ORIGIN}" + canonicalPath;
      })();
      (async function() {
        try {
          // ヘッダーはbody内にあるため、localでも確実にLoginリンクを取得できるまで待つ。
          if (document.readyState === 'loading') {
            await new Promise(function(resolve) {
              document.addEventListener('DOMContentLoaded', resolve, { once: true });
            });
          }

          const loginMenu = document.querySelector('.menu-button.login a.link');
          if (!loginMenu) return;

          if (
            window.location.hostname === 'localhost' ||
            window.location.hostname === '127.0.0.1' ||
            window.location.hostname === '::1'
          ) {
            // localでは実認証を行わないが、UI確認のため ?auth=login でLogout表示を再現できるようにする。
            const localAuthPreview = new URLSearchParams(window.location.search).get('auth');
            const localIsLogin = localAuthPreview === 'login';
            const localLabel = localIsLogin ? "Logout" : "Login";
            loginMenu.href = '#';
            loginMenu.setAttribute('aria-disabled', 'true');
            loginMenu.setAttribute('tabindex', '-1');
            loginMenu.setAttribute('aria-label', localLabel);
            loginMenu.textContent = localLabel;
            loginMenu.addEventListener('click', function(event) {
              event.preventDefault();
            });
            return;
          }

          const controller = new AbortController();
          const timeoutId = setTimeout(function() {
            controller.abort();
          }, 10000);
          let response;

          try {
            response = await fetch(`${window.location.origin}/auth/status`, {
              signal: controller.signal,
            });
          } finally {
            clearTimeout(timeoutId);
          }

          let isLogin = false;
          if (response.status === 200 || response.status === 403) {
            isLogin = true;
          }

          if (isLogin === true) {
            const logoutLabel = "Logout";
            loginMenu.href = "/auth/logout";
            loginMenu.setAttribute('aria-label', logoutLabel);
            loginMenu.textContent = logoutLabel;
          } else {
            const loginLabel = "Login";
            loginMenu.href = loginMenu.dataset.loginHref || "/auth/login";
            loginMenu.setAttribute('aria-label', loginLabel);
            loginMenu.textContent = loginLabel;
          }

        } catch (error) {
          console.error('Error fetching auth status:', error);
        }
      })();

    block head
  body
    include ../includes/_global_header
    block content

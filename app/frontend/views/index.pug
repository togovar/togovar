extend layouts/application

append variables
  - locals.currentPage = "home";
  - locals.description = "TogoVar is an integrated database of Japanese genomic variation, providing allele frequencies and annotations for human variants.";

block head
  link(href="/togovar.jsonld" rel="alternate" type="application/ld+json")
  //- Critical CSS: inlined to prevent FOUC while main CSS loads asynchronously.
  //- These rules mirror the sources listed below; keep in sync when editing SCSS.
  //-   html/body/box-sizing → stylesheets/foundation/_base.scss
  //-   #GlobalHeader, .button-view → stylesheets/object/component/ (each component file)
  //-   .module-tabs-view → stylesheets/object/component/_module-tabs-view.sass
  //-   .LayoutMainAside, #SearchResultsView → stylesheets/layout/_layout.sass
  //-   table.results-view column widths → stylesheets/object/component/_results-view.scss
  //-   .drawer-view → stylesheets/object/component/_drawer-view.sass
  style(nonce=cspNonce).
    html{height:100%}
    @media(prefers-reduced-motion:no-preference){html{scroll-behavior:smooth}}
    *,*::before,*::after{box-sizing:border-box}
    body{margin:0;font-size:10px;font-family:'Roboto Condensed','Arial Narrow',Arial,sans-serif;color:#444;padding-top:50px!important;overflow:hidden;-moz-osx-font-smoothing:grayscale;-webkit-font-smoothing:antialiased}
    h1,h2{margin-top:0;line-height:1.2}
    ul{margin-top:0}
    img,svg{vertical-align:middle}
    button{margin:0;font-family:inherit;border-radius:0}
    #GlobalHeader{display:flex;justify-content:space-between;height:50px;background:#fff;position:fixed;box-shadow:0 2px 2px rgba(0,0,0,.2);width:100%;top:0;z-index:10200}
    #GlobalHeader>.left{display:flex;position:relative;padding:10px 18px;top:-2px}
    #GlobalHeader .logotype{width:101px;height:31px;display:block;position:relative;left:-5px;margin-right:.3rem}
    #GlobalHeader span.summary{padding-top:8px;font-size:12px;font-weight:400}
    #GlobalHeader nav.dropdown-view{padding-top:6px;padding-left:8px;font-size:14px}
    #GlobalHeader>.right{position:relative;font-size:14px;align-self:center}
    .button-view{box-sizing:border-box;border:0;position:relative;font-weight:700}
    .button-view.-dropdown{line-height:20px;padding:0 1.4em 0 .8em;border-radius:.8em;color:#fff;background:#125263}
    .button-view.-dropdown:after{content:'';position:absolute;top:50%;right:.36rem;width:0;height:0;border-left:.25rem solid transparent;border-right:.25rem solid transparent;border-top:.32rem solid currentColor;transform:translateY(-50%)}
    .module-tabs-view{background-color:#0f6272;color:#fff}
    .module-tabs-view>.tabscontainer>ul{margin:0;padding:4px 18px 0}
    .module-tabs-view>.tabscontainer>ul>li{display:inline-block;font-size:14px;font-weight:700;line-height:24px;padding:2px 12px 0}
    .module-tabs-view>.sectionscontainer{min-height:72px;background-color:#117f93}
    .module-tabs-view>.sectionscontainer>.section{visibility:hidden;position:absolute}
    .module-tabs-view>.sectionscontainer>.section.-current{visibility:inherit;position:inherit}
    #SearchInputView{min-height:104px}
    #SimpleSearchView{padding:14px;min-height:72px}
    #SearchResultsView{height:var(--search-results-height,calc(100vh - 184px))}
    .LayoutMainAside{display:flex;height:calc(100% - 30px);min-height:0}
    .LayoutMainAside>.LayoutMain{width:calc(100% - 300px);min-height:0}
    .LayoutMainAside>.LayoutAside{width:300px;height:100%;min-height:0;overflow:hidden;position:relative;background:#125263}
    #ResultsView{padding:10px 18px 18px;position:relative}
    #ResultsView>.header{white-space:nowrap;position:relative;display:flex;justify-content:space-between}
    #ResultsView>.header>.left>.heading{display:inline-block;font-size:16px;margin-right:8px;margin-bottom:-2px}
    #ResultsView>.header>.left>.status{display:inline-block;font-size:12px;min-width:12em}
    #ResultsView>.header>.right{position:relative;top:4px;min-height:16px;list-style:none;display:flex;gap:5px;align-items:flex-start;padding:0 0 18px;margin:0}
    #ResultsView>.tablecontainer{overflow-x:auto;overflow-y:hidden;margin-top:-15px;margin-right:-18px;padding-bottom:20px}
    table.results-view{caption-side:bottom;border-collapse:collapse;white-space:nowrap;font-size:14px;line-height:18px;border-right:solid 18px #fff;width:100%}
    table.results-view>thead>tr{height:64px;border-bottom:solid 2px #444}
    table.results-view thead,table.results-view tbody,table.results-view tr,table.results-view td,table.results-view th{border-color:inherit;border-style:solid;border-width:0}
    table.results-view th{position:relative;text-align:inherit}
    table.results-view th>span{position:absolute;display:inline-block;transform-origin:0 100%;transform:rotate(-20deg);bottom:0;left:9px;font-size:12px;line-height:1;white-space:nowrap}
    table.results-view th.togovar_id,table.results-view td.togovar_id{width:124px;min-width:124px;max-width:124px}
    table.results-view th.refsnp_id,table.results-view td.refsnp_id{width:116px;min-width:116px;max-width:116px}
    table.results-view th.position,table.results-view td.position{width:164px;min-width:164px;max-width:164px}
    table.results-view th.ref_alt,table.results-view td.ref_alt{width:104px;min-width:104px;max-width:104px}
    table.results-view th.type,table.results-view td.type{width:96px;min-width:96px;max-width:96px}
    table.results-view th.type{display:none}
    table.results-view th.gene,table.results-view td.gene{width:116px;min-width:116px;max-width:116px}
    table.results-view th.alt_frequency,table.results-view td.alt_frequency{width:120px;min-width:120px;max-width:120px}
    table.results-view th.consequence,table.results-view td.consequence{width:176px;min-width:176px;max-width:176px}
    table.results-view th.clinical_significance,table.results-view td.clinical_significance{width:276px;min-width:276px;max-width:276px}
    table.results-view th.alphamissense,table.results-view td.alphamissense{width:71px;min-width:71px;max-width:71px}
    table.results-view th.sift,table.results-view td.sift{width:57px;min-width:57px;max-width:57px}
    table.results-view th.polyphen,table.results-view td.polyphen{width:70px;min-width:70px;max-width:70px}
    .drawer-view{width:100%;position:fixed;background-color:#444;color:#fff;z-index:10300;bottom:-370px}
    .drawer-view>.header{box-sizing:border-box;padding:0 16px;line-height:30px;height:30px;border-top:solid 1px rgba(255,255,255,.4);border-bottom:solid 1px rgba(0,0,0,.2)}
    .drawer-view>.header>.mark{display:inline-block;position:relative;vertical-align:middle;margin-right:.7em;margin-top:-.8em;width:7px;height:7px;border-top:solid 1px #fff;border-left:solid 1px #fff;transform:rotate(225deg)}
    .drawer-view>.header>.heading{display:inline-block;font-size:15px;font-weight:700;margin:0}
    .drawer-view>.configuration{position:absolute;top:5px;right:16px;font-size:12px;pointer-events:none;opacity:0;max-width:calc(100vw - 120px);text-align:right;white-space:nowrap;overflow-x:auto}
    .drawer-view>.content{position:relative;overflow:hidden}
    .drawer-view>.content>.chromosomes{box-sizing:content-box;padding:10px 18px 16px;height:344px;text-align:center;white-space:nowrap;overflow-x:auto}
    body:not(.-layout-ready) #SearchResultsView .tablecontainer tbody,body:not(.-layout-ready) #SearchResultsView #Messages,body:not(.-layout-ready) #SearchResultsView #RowIndicator,body:not(.-layout-ready) #SearchResultsView .LayoutAside,body:not(.-layout-ready) #Karyotype{opacity:0;pointer-events:none}
    body.-layout-ready #SearchResultsView .tablecontainer tbody,body.-layout-ready #SearchResultsView #Messages,body.-layout-ready #SearchResultsView #RowIndicator,body.-layout-ready #SearchResultsView .LayoutAside,body.-layout-ready #Karyotype{opacity:1;pointer-events:auto}
  - var mainCssFiles = htmlWebpackPlugin.files.css.filter(x => x.match(/^\/css\/main-/))
  each css in mainCssFiles
    link(rel="preload" href=css as="style" data-activate-stylesheet)
  noscript
    each css in mainCssFiles
      link(href=css, rel="stylesheet")
  each js in htmlWebpackPlugin.files.js.filter(x => x.match(/^\/js\/main-/))
    script(type="text/javascript", src=js, defer)
  script(nonce=cspNonce).
    document.querySelectorAll('link[data-activate-stylesheet]').forEach(function(link) {
      link.onload = function() { this.rel = 'stylesheet'; };
    });

block content
  include includes/_search_results_main
  include includes/_karyotype
  include includes/_activity_indicator

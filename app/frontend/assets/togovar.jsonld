    },
    {
      "@type": "Dataset",
      "@id": "__TOGOVAR_SITE_ORIGIN__/doc/datasets/jga_snp",
      "name": "Variant set aggregated from SNP-chip data in NBDC Human Database/JGA",
      "description": "JGA-SNP dataset is a frequency dataset that has aggregated variants detected from SNP-chip data in the NBDC Human Database/Japanese Genotype-phenotype Archive (JGA). All JGA data for which an approval for creating secondary data has been obtained are to be aggregated. Note that no variants with 5 alternate alleles or less are included.",
      "url": "__TOGOVAR_SITE_ORIGIN__/doc/datasets/jga_snp",
      "identifier": "JGA-SNP",

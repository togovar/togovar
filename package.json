  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production webpack --config app/frontend/config/webpack.config.prod.js --color --progress",
    "dev": "cross-env NODE_ENV=development NODE_OPTIONS=--experimental-strip-types node app/frontend/server",
    "start": "npm run dev",
    "start:prod": "cross-env NODE_ENV=production NODE_OPTIONS=--experimental-strip-types node app/frontend/server",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:server",
    "typecheck:frontend": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "build:check": "npm run typecheck && npm run build",
    "format": "cross-env NODE_OPTIONS=--experimental-strip-types prettier --write app/frontend/src",
    "format:check": "cross-env NODE_OPTIONS=--experimental-strip-types prettier --check app/frontend/src",
    "lint": "npm run lint:eslint && npm run lint:css",
    "lint:css": "stylelint app/frontend/stylesheets/**/*.{css,scss,sass}",
    "lint:eslint": "eslint app/frontend",
    "verify": "npm run lint && npm run typecheck && npm run build"
  },
